$Common = "../Common.ui";
$Sounds = "../Sounds.ui";

Group #StatsRoot {
    Visible: true;
    Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
    LayoutMode: Center;

    $Common.@Panel #StatsMainWindow {
        Anchor: (Width: 500, Height: 390);
        LayoutMode: Top;

        // Header
        Group #HeaderRow {
            Anchor: (Height: 50);
            LayoutMode: Center;
            Label #StatsTitle {
                Text: "ITEM STATISTICS";
                Anchor: (Height: 38);
                Style: (FontSize: 18, TextColor: #b4c8c9, RenderBold: true, RenderUppercase: true,
                        VerticalAlignment: Center, HorizontalAlignment: Center, FontName: "Secondary");
                HitTestVisible: false;
            }
        }

        $Common.@ContentSeparator {}

        // Item Info Row
        Group #ItemInfoRow {
            Anchor: (Height: 80, Top: 12, Left: 16, Right: 16);
            LayoutMode: Left;

            ItemSlot #StatsItemSlot {
                Anchor: (Width: 64, Height: 64);
                ShowQualityBackground: true;
            }

            Group {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Left: 16, Top: 10);
                HitTestVisible: false;

                Label #StatsItemName {
                    Text: "Item Name";
                    Anchor: (Height: 26);
                    Style: (FontSize: 16, TextColor: #FFFFFF, RenderBold: true, VerticalAlignment: Center);
                    HitTestVisible: false;
                }
                Label #StatsItemLevel {
                    Text: "Level 0";
                    Anchor: (Height: 20);
                    Style: (FontSize: 13, TextColor: #55FF55, VerticalAlignment: Center);
                    HitTestVisible: false;
                }
            }
        }

        $Common.@PanelSeparatorFancy { @Anchor = (Top: 10, Bottom: 8); }

        // Stats Section
        Group #StatsSection {
            Anchor: (Left: 16, Right: 16);
            LayoutMode: Top;

            // Enemies Defeated
            Group #KillsRow {
                Anchor: (Height: 44);
                LayoutMode: Left;
                HitTestVisible: false;

                Group {
                    Anchor: (Width: 32, Height: 32);
                    Background: PatchStyle(TexturePath: "Assets/TokenSystemVampirism.png");
                    HitTestVisible: false;
                }
                Label #KillsLabel {
                    Text: "Enemies Defeated";
                    FlexWeight: 1;
                    Anchor: (Height: 44, Left: 12);
                    Style: (FontSize: 14, TextColor: #96a9be, VerticalAlignment: Center);
                    HitTestVisible: false;
                }
                Label #KillsValue {
                    Text: "0";
                    Anchor: (Width: 90, Height: 44);
                    Style: (FontSize: 18, TextColor: #E8A93B, RenderBold: true,
                            VerticalAlignment: Center, HorizontalAlignment: End);
                    HitTestVisible: false;
                }
            }

            $Common.@ContentSeparator { @Anchor = (Top: 3, Bottom: 3); }

            // Ore Blocks Mined
            Group #BlocksRow {
                Anchor: (Height: 44);
                LayoutMode: Left;
                HitTestVisible: false;

                Group {
                    Anchor: (Width: 32, Height: 32);
                    Background: PatchStyle(TexturePath: "Assets/TokenSystemVeinMiner.png");
                    HitTestVisible: false;
                }
                Label #BlocksLabel {
                    Text: "Ore Blocks Mined";
                    FlexWeight: 1;
                    Anchor: (Height: 44, Left: 12);
                    Style: (FontSize: 14, TextColor: #96a9be, VerticalAlignment: Center);
                    HitTestVisible: false;
                }
                Label #BlocksValue {
                    Text: "0";
                    Anchor: (Width: 90, Height: 44);
                    Style: (FontSize: 18, TextColor: #E8A93B, RenderBold: true,
                            VerticalAlignment: Center, HorizontalAlignment: End);
                    HitTestVisible: false;
                }
            }

            $Common.@ContentSeparator { @Anchor = (Top: 3, Bottom: 3); }

            // Total XP
            Group #XpRow {
                Anchor: (Height: 44);
                LayoutMode: Left;
                HitTestVisible: false;

                Group {
                    Anchor: (Width: 32, Height: 32);
                    Background: PatchStyle(TexturePath: "Assets/TokenSystemEnergy.png");
                    HitTestVisible: false;
                }
                Label #XpLabel {
                    Text: "Total XP Earned";
                    FlexWeight: 1;
                    Anchor: (Height: 44, Left: 12);
                    Style: (FontSize: 14, TextColor: #96a9be, VerticalAlignment: Center);
                    HitTestVisible: false;
                }
                Label #XpValue {
                    Text: "0";
                    Anchor: (Width: 90, Height: 44);
                    Style: (FontSize: 18, TextColor: #96b8e0, RenderBold: true,
                            VerticalAlignment: Center, HorizontalAlignment: End);
                    HitTestVisible: false;
                }
            }
        }

        Group { FlexWeight: 1; }

        $Common.@ContentSeparator {}

        Group #FooterRow {
            Anchor: (Height: 55, Top: 8, Left: 16, Right: 16); LayoutMode: Left;
            Group { FlexWeight: 1; }
            $Common.@CancelTextButton #CloseButton { @Text = "CLOSE"; @Anchor = (Width: 150); }
        }
    }
}
