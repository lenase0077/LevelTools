$C = "../Common.ui";
$Sounds = "../Sounds.ui";
$PackBrowser = "AssetPackSaveBrowser.ui";

@InputLabel = Label {
  Anchor: (Left: 6, Right: 16, Width: 220);
  Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center);
};

$C.@PageOverlay #MainPage {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 420);

    #Title {
      $C.@Title {
        @Text = %server.customUI.prefabSavePage.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Group #TargetPack {
        LayoutMode: Top;
        Anchor: (Bottom: 16);

        Label {
          Text: %server.customUI.prefabSavePage.targetPack;
          Anchor: (Bottom: 8);
          Style: $C.@DefaultLabelStyle;
        }

        Group {
          LayoutMode: Left;

          Group #SelectedPackBox {
            Anchor: (Right: 8, Height: 38);
            Background: $C.@InputBoxBackground;
            Padding: (Horizontal: 10);
            FlexWeight: 1;

            Label #SelectedPackLabel {
              Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center);
              Text: %server.customUI.assetPackBrowser.noneSelected;
            }
          }

          $C.@SecondaryTextButton #BrowsePackButton {
            @Anchor = (Width: 150);
            Text: %server.customUI.prefabSavePage.browsePack;
          }
        }
      }

      Group {
        LayoutMode: Top;
        Anchor: (Bottom: 16);

        Label {
          Text: %server.customUI.prefabSavePage.name;
          Anchor: (Bottom: 8);
          Style: $C.@DefaultLabelStyle;
        }

        $C.@TextField #NameInput {
          PlaceholderText: %server.customUI.prefabSavePage.namePlaceholder;
        }
      }

      Group {
        Anchor: (Vertical: 8, Height: 1);
        Background: #5e512c(0.0);
      }

      Group #Entities {
        LayoutMode: Left;
        Anchor: (Bottom: 12);

        @InputLabel {
          Text: %server.customUI.prefabSavePage.includeEntities;
        }

        $C.@CheckBox #CheckBox {
          Value: true;
        }
      }

      Group #Empty {
        LayoutMode: Left;
        Anchor: (Bottom: 12);

        @InputLabel {
          Text: %server.customUI.prefabSavePage.includeEmpty;
        }

        $C.@CheckBox #CheckBox {
          Value: false;
        }
      }

      Group #Overwrite {
        LayoutMode: Left;
        Anchor: (Bottom: 12);

        @InputLabel {
          Text: %server.customUI.prefabSavePage.overwrite;
        }

        $C.@CheckBox #CheckBox {
          Value: false;
        }
      }

      Group #FromClipboard {
        LayoutMode: Left;
        Anchor: (Bottom: 12);

        @InputLabel {
          Text: %server.customUI.prefabSavePage.fromClipboard;
        }

        $C.@CheckBox #CheckBox {
          Value: false;
        }
      }

      Group #UsePlayerAnchor {
        LayoutMode: Left;
        Anchor: (Bottom: 12);

        @InputLabel {
          Text: %server.customUI.prefabSavePage.usePlayerAnchor;
        }

        $C.@CheckBox #CheckBox {
          Value: false;
        }
      }

      Group #ClearSupport {
        LayoutMode: Left;
        Anchor: (Bottom: 16);

        @InputLabel {
          Text: %server.customUI.prefabSavePage.clearSupport;
        }

        $C.@CheckBox #CheckBox {
          Value: false;
        }
      }

      Group {
        Anchor: (Vertical: 8, Height: 1);
        Background: #5e512c(0.0);
      }

      Group {
        LayoutMode: Center;
        Anchor: (Top: 8);

        $C.@TextButton #SaveButton {
          @Sounds = $Sounds.@SaveSettings;
          @Anchor = (Right: 4);
          Text: %server.customUI.prefabSavePage.save;
          FlexWeight: 1;
        }

        $C.@SecondaryTextButton #CancelButton {
          @Sounds = $Sounds.@ButtonsCancel;
          @Anchor = (Left: 4);
          Text: %server.customUI.cancel;
          FlexWeight: 1;
        }
      }
    }
  }
}

$C.@PageOverlay #PackBrowserPage {
  LayoutMode: Middle;
  Visible: false;

  $C.@DecoratedContainer {
    Anchor: (Width: 500, Height: 550);

    #Title {
      $C.@Title {
        @Text = %server.customUI.assetPackBrowser.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      $PackBrowser.@AssetPackSaveBrowserContent {}
    }
  }
}

$C.@PageOverlay #CreatePackPage {
  LayoutMode: Middle;
  Visible: false;

  $C.@DecoratedContainer {
    Anchor: (Width: 500);

    #Title {
      $C.@Title {
        @Text = %server.customUI.assetPackBrowser.create.title;
      }
    }

    #Content {
      $PackBrowser.@CreatePackFormContent {}
    }
  }
}

$C.@BackButton {}
